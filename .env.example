NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_me

KIMCHI_BASE_URL=https://api.kimchi.cast.ai/v1
KIMCHI_API_KEY=replace_me
KIMCHI_MODEL=kimi-k2.5
# Non-thinking model used for the one clustering call per /analyze.
# Kimi K2.5 burns its token budget on reasoning before emitting JSON;
# nemotron-3-super-fp4 returns structured JSON in `content` directly.
KIMCHI_CLUSTER_MODEL=nemotron-3-super-fp4

GITHUB_TOKEN=
